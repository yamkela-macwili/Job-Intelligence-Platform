# ============================================
# Database Configuration (Azure PostgreSQL)
# ============================================
# Format: postgresql://username:password@host.postgres.database.azure.com:5432/database_name?sslmode=require
DATABASE_URL=postgresql://user:password@hostname.postgres.database.azure.com:5432/job_intelligence?sslmode=require

# ============================================
# Azure OpenAI Configuration
# ============================================
AZURE_AI_API_KEY=your-azure-openai-api-key-here
AZURE_AI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins (leave empty to allow all)
# Example: https://your-project.vercel.app,https://yourdomain.com
CORS_ORIGINS=https://your-project.vercel.app

# ============================================
# Application Configuration
# ============================================
# Set to 'production' for Azure deployment
ENVIRONMENT=production

# Set to False for production deployments
DEBUG=False

# Set to WARNING or ERROR for production
LOG_LEVEL=INFO

# ============================================
# File Upload Configuration
# ============================================
# Max file upload size (in bytes, default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Cache TTL in hours
CACHE_TTL_HOURS=24
